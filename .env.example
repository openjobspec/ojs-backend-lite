# OJS Backend Lite (In-Memory) - Environment Variables
# Copy to .env and adjust values as needed.

# Server
OJS_PORT=8080

# gRPC
OJS_GRPC_PORT=9090

# Authentication
# Set a strong API key for any shared/non-local environment.
OJS_API_KEY=REPLACE_WITH_LONG_RANDOM_API_KEY
# The lite backend defaults to true for local development convenience.
OJS_ALLOW_INSECURE_NO_AUTH=true

# HTTP timeouts
OJS_READ_TIMEOUT=30s
OJS_WRITE_TIMEOUT=30s
OJS_IDLE_TIMEOUT=120s

# Shutdown
OJS_SHUTDOWN_TIMEOUT=30s

# Retention policies (how long completed/cancelled/discarded jobs are kept)
OJS_RETENTION_COMPLETED=1h
OJS_RETENTION_CANCELLED=24h
OJS_RETENTION_DISCARDED=24h

# Persistence (empty = in-memory only, set path to enable snapshot persistence)
# OJS_PERSIST=/tmp/ojs-lite.db
