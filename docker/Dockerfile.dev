# Development Dockerfile — mounts source for live reload
FROM golang:1.24-alpine

RUN apk add --no-cache git

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN go build -o /usr/local/bin/ojs-server ./cmd/ojs-server

EXPOSE 8080 9090

ENV OJS_ALLOW_INSECURE_NO_AUTH=true

ENTRYPOINT ["ojs-server"]
